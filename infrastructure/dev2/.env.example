# Postgres credentials for Temporal's persistence layer.
# Set these to point at a running Postgres reachable from the temporal container
# on the same Docker network. The compose file reuses an existing `dev2-postgres`
# container as POSTGRES_SEEDS — adjust if your setup uses a different name.
#
# To set up:
#   cp .env.example .env
#   # then fill in real values (.env is gitignored)
POSTGRES_USER=replace-me
POSTGRES_PWD=replace-me
