{
  "name": "@temporal-memory/t02-operator-approval",
  "version": "0.0.1",
  "description": "T02 — Human-in-the-loop approval workflow with durable signals, query, and memory audit trail.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "worker": "node --enable-source-maps dist/worker.js",
